# SEC EDGAR requires a User-Agent header for API access.
# Format: Your Full Name (your_email@example.com)
USER_AGENT=Your Name (email@example.com)

# Google Gemini API key for AI-powered filing analysis.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
